# ---------------------------------------------------------------------------
# On COOLIFY you do NOT need most of this. Coolify auto-generates the magic
# variables referenced in docker-compose.yml:
#   SERVICE_PASSWORD_JWT           -> injected as JWT_SECRET
#   SERVICE_PASSWORD_POSTGRES      -> Postgres password (and the Node DATABASE_URL)
#   SERVICE_FQDN_DASHBOARD_80      -> public URL for the dashboard UI
# Just edit the FQDN value in docker-compose.yml to your real domain and set the
# app-level vars below in the Coolify UI.
#
# For a LOCAL `docker compose up` (no Coolify), copy this to .env — the magic
# vars are NOT auto-filled there, so you must provide both SERVICE_PASSWORD_*.
# ---------------------------------------------------------------------------

# Required locally (Coolify generates these for you)
SERVICE_PASSWORD_JWT=change-me-to-a-long-random-string
SERVICE_PASSWORD_POSTGRES=change-me-too

# --- Postgres (backs the Node API) ---
POSTGRES_USER=postgres
POSTGRES_DB=smart_inventary

# Admin account seeded on first boot (also used by the monitor service -> Node)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Default password backfilled for seeded employees
DEFAULT_EMPLOYEE_PASSWORD=employee123

# Products expiring within this many days are flagged
EXPIRY_ALERT_DAYS=180

# --- Monitor-AI camera (port 5001) ---
# Room this camera watches; must match the RFID room name in the Node DB.
MONITOR_ROOM=Room 1
# RTSP URL of the IP camera. Leave empty to fall back to a local webcam
# (not available inside a container). Credentials are injected at runtime.
MONITOR_CAMERA_URL=
MONITOR_CAMERA_USER=admin
MONITOR_CAMERA_PASSWORD=123456
