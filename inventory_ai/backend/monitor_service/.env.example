# Copy to inventory_ai/.env and fill in for the real camera.
# Never commit real credentials - this file only documents the variable names.

# RTSP URL WITHOUT credentials embedded (they're injected from the two vars
# below at runtime so they never end up in source control or logs).
# Example: rtsp://192.168.29.14/stream1
MONITOR_CAMERA_URL=
MONITOR_CAMERA_USER=admin
MONITOR_CAMERA_PASSWORD=123456

# Which room this camera covers - must match a room name used in server/db.js
# (e.g. "Room 1", "Room 2", "Room 3").
MONITOR_ROOM=Room 1

# Node backend base URL and the admin credentials this service authenticates
# with to read active RFID sessions (same login the dashboard's admin uses).
MONITOR_NODE_API_URL=http://127.0.0.1:4000/api
MONITOR_NODE_ADMIN_USERNAME=admin
MONITOR_NODE_ADMIN_PASSWORD=admin123

MONITOR_PERSON_CONFIDENCE=0.5
MONITOR_UNKNOWN_ALERT_SECONDS=3.0
MONITOR_SESSION_POLL_SECONDS=1.0
# Sleep (in ~30ms units) added per frame to keep CPU inference watchable;
# 0 = no artificial delay. Irrelevant once a real GPU is used.
MONITOR_FRAME_SKIP=0
MONITOR_HOST=0.0.0.0
MONITOR_PORT=5001
